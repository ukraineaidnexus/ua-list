       var t = btn.querySelector(".copy-text");
@@ -147,5 +147,35 @@
     });
   });
   </script>
+  <script>
+  (function () {
+    if (location.search.indexOf("only=1") === -1 || !location.hash) return;
+    var id = location.hash.slice(1);
+    var match = document.querySelectorAll(".cards article");
+    var found = false;
+    match.forEach(function (a) { if (a.id === id) found = true; });
+    if (!found) return;
+    match.forEach(function (a) { if (a.id !== id) a.hidden = true; });
+    document.querySelectorAll("main section").forEach(function (s) {
+      var cards = s.querySelectorAll(".cards article");
+      if (cards.length && !s.querySelector(".cards article:not([hidden])")) s.hidden = true;
+    });
+    var bar = document.createElement("p");
+    bar.className = "only-note";
+    bar.appendChild(document.createTextNode(document.body.dataset.showingOne + " "));
+    var link = document.createElement("a");
+    link.href = location.pathname + location.hash;
+    link.textContent = document.body.dataset.showAll;
+    link.addEventListener("click", function (e) {
+      e.preventDefault();
+      document.querySelectorAll("main section[hidden], .cards article[hidden]").forEach(function (el) { el.hidden = false; });
+      history.replaceState(null, "", location.pathname + location.hash);
+      bar.remove();
+    });
+    bar.appendChild(link);
+    var main = document.querySelector("main");
+    if (main) main.insertBefore(bar, main.firstChild);
+  })();
+  </script>
 </body>
 </html>
